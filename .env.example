# ─── SAFE TO EXPOSE (visible in browser) ───────────────────────────────────
# YouTube Data API v3 — restrict this key to your domain in Google Console!
# console.cloud.google.com → API key → Application restrictions → HTTP referrers
VITE_YOUTUBE_API_KEY=your_youtube_key

# Supabase (public anon key — safe by design)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backend URL — points to your glint-backend server
VITE_BACKEND_URL=http://localhost:3001

# ─── NEVER PUT THESE HERE ───────────────────────────────────────────────────
# GROQ_API_KEY → goes in glint-backend/.env only
# SPOTIFY_CLIENT_ID → goes in glint-backend/.env only
# SPOTIFY_CLIENT_SECRET → goes in glint-backend/.env only
