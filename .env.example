# Supabase
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# YouTube Data API
VITE_YOUTUBE_API_KEY=your_youtube_data_api_key

# Groq API (for backend, but we'll expose it to frontend for simplicity in this example)
# In production, you should proxy this through your backend to keep the key secure.
VITE_GROQ_API_KEY=your_groq_api_key
